# Скопіюй на EC2 як .env у каталозі my-app (або експортуй у systemd/pm2).
# Не коміть файли з реальними паролями та ключами.

# Якщо підключиш бекенд до RDS (PostgreSQL приклад):
# DATABASE_URL=postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DATABASE

# Регіон і бакет для AWS SDK / перевірок (IAM Role на EC2 замість ключів у файлах):
AWS_REGION=eu-central-1
S3_BUCKET_NAME=your-unique-bucket-name

# Лише для локальної розробки з ключами IAM-користувача (на EC2 краще IAM Role):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
